/* ape.ld — Linker script forcing page-aligned segments for PE compatibility */
OUTPUT_FORMAT("elf64-x86-64")
ENTRY(_start)

SECTIONS {
    . = 0x400000 + SIZEOF_HEADERS;
    .note : { *(.note*) }

    . = ALIGN(0x1000);
    .text : { *(.text .text.*) }

    . = ALIGN(0x1000);
    .rodata : { *(.rodata .rodata.*) }

    . = ALIGN(0x1000);
    .data : { *(.data .data.*) }
    .bss : { *(.bss .bss.* COMMON) }

    /DISCARD/ : { *(.comment) *(.eh_frame*) }
}
